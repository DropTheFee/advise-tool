<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SüRJ — Set Your Password</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@300;400;700;900&family=DM+Sans:wght@300;400;500&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{--bg:#060F18;--card:#0a1624;--teal:#1A8A72;--tealb:#6EDFC8;--purple:#6B3FA0;--purpleb:#9B6FD0;--gold:#C8860A;--goldb:#F5C842;--white:#F0F4F8;--muted:#7A9BB5;--border:rgba(110,223,200,0.12);}
body{background:var(--bg);color:var(--white);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background-image:radial-gradient(ellipse at 20% 50%,rgba(107,63,160,0.15),transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(26,138,114,0.1),transparent 50%);}
.wrap{width:100%;max-width:420px;}
.logo{font-family:'Fraunces',serif;font-size:48px;font-weight:900;background:linear-gradient(135deg,#9B6FD0,#6EDFC8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center;margin-bottom:4px;}
.logo-sub{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;color:var(--muted);letter-spacing:3px;text-transform:uppercase;text-align:center;margin-bottom:32px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:36px;}
.card-title{font-family:'Fraunces',serif;font-size:22px;font-weight:900;margin-bottom:6px;}
.card-sub{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:24px;}
.welcome-banner{background:rgba(200,134,10,0.08);border:1px solid rgba(200,134,10,0.2);border-radius:10px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:var(--goldb);line-height:1.5;}
.error-msg{background:rgba(184,50,50,0.12);border:1px solid rgba(184,50,50,0.3);border-radius:8px;padding:10px 14px;font-size:13px;color:#E05555;margin-bottom:16px;display:none;}
label{display:block;font-family:'Syne',sans-serif;font-size:9px;font-weight:700;color:var(--tealb);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.fg{margin-bottom:16px;}
input{width:100%;background:#0d1d30;border:1px solid var(--border);border-radius:8px;padding:12px 14px;color:var(--white);font-family:'DM Sans',sans-serif;font-size:15px;outline:none;transition:border-color 0.2s;}
input:focus{border-color:rgba(110,223,200,0.4);}
.strength-row{display:flex;gap:4px;margin-top:6px;height:3px;}
.strength-bar{flex:1;border-radius:2px;background:rgba(255,255,255,0.08);transition:background 0.3s;}
.strength-bar.weak{background:#B83232;}
.strength-bar.ok{background:var(--goldb);}
.strength-bar.strong{background:var(--tealb);}
.strength-label{font-size:10px;color:var(--muted);margin-top:4px;height:14px;}
button{width:100%;padding:14px;background:linear-gradient(135deg,var(--purple),var(--teal));border:none;border-radius:8px;color:var(--white);font-family:'Syne',sans-serif;font-size:13px;font-weight:700;cursor:pointer;letter-spacing:0.5px;transition:all 0.2s;margin-top:8px;}
button:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(107,63,160,0.3);}
button:disabled{opacity:0.5;cursor:not-allowed;transform:none;}
.rules{font-size:11px;color:var(--muted);margin-top:12px;line-height:1.7;}
.rules li{margin-left:16px;}
</style>
</head>
<body>
<div class="wrap">
  <div class="logo">SüRJ</div>
  <div class="logo-sub">ADVISE Discovery Tool</div>
  <div class="card">
    <div class="card-title">Set Your Password</div>
    <div class="card-sub">Your account was created with a temporary password. Set your own password to continue — you won't be asked again.</div>
    <div class="welcome-banner" id="welcome-banner" style="display:none;">👋 Welcome! You're almost in.</div>
    <div class="error-msg" id="err"></div>
    <div class="fg">
      <label>New Password</label>
      <input type="password" id="newPassword" placeholder="Min 8 characters" oninput="checkStrength()" autocomplete="new-password">
      <div class="strength-row"><div class="strength-bar" id="sb1"></div><div class="strength-bar" id="sb2"></div><div class="strength-bar" id="sb3"></div><div class="strength-bar" id="sb4"></div></div>
      <div class="strength-label" id="strength-label"></div>
    </div>
    <div class="fg">
      <label>Confirm Password</label>
      <input type="password" id="confirmPassword" placeholder="Repeat your password" autocomplete="new-password">
    </div>
    <button id="btn" onclick="doChange()">Set Password &amp; Enter Tool →</button>
    <ul class="rules">
      <li>At least 8 characters</li>
      <li>Mix of letters and numbers recommended</li>
      <li>This replaces the temporary password immediately</li>
    </ul>
  </div>
</div>
<script>
// Show welcome banner for first-timers (came from a temp password)
document.getElementById('welcome-banner').style.display = 'block';

function checkStrength() {
  var p = document.getElementById('newPassword').value;
  var score = 0;
  if (p.length >= 8) score++;
  if (p.length >= 12) score++;
  if (/[A-Z]/.test(p) && /[a-z]/.test(p)) score++;
  if (/[0-9!@#$%^&*]/.test(p)) score++;
  var classes = ['','weak','weak','ok','strong'];
  var labels = ['','Too short','Weak','Good','Strong 💪'];
  ['sb1','sb2','sb3','sb4'].forEach(function(id, i) {
    document.getElementById(id).className = 'strength-bar' + (i < score ? ' ' + (classes[score]||'') : '');
  });
  document.getElementById('strength-label').textContent = labels[score] || '';
}

function doChange() {
  var np = document.getElementById('newPassword').value.trim();
  var cp = document.getElementById('confirmPassword').value.trim();
  var err = document.getElementById('err');
  err.style.display = 'none';

  if (!np || np.length < 8) {
    err.textContent = 'Password must be at least 8 characters.'; err.style.display = 'block'; return;
  }
  if (np !== cp) {
    err.textContent = 'Passwords do not match.'; err.style.display = 'block'; return;
  }

  var btn = document.getElementById('btn');
  btn.disabled = true; btn.textContent = 'Saving...';

  fetch('/api/change-password', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ newPassword: np, confirmPassword: cp })
  }).then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.ok) {
      btn.textContent = '✓ Password set — entering tool...';
      setTimeout(function(){ window.location.href = '/'; }, 1000);
    } else {
      err.textContent = d.error || 'Failed to set password.'; err.style.display = 'block';
      btn.disabled = false; btn.textContent = 'Set Password & Enter Tool →';
    }
  }).catch(function() {
    err.textContent = 'Network error — please try again.'; err.style.display = 'block';
    btn.disabled = false; btn.textContent = 'Set Password & Enter Tool →';
  });
}
</script>
</body>
</html>
